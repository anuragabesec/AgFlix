# Server Config
PORT=5000
NODE_ENV=development

# Database
# For production use: mongodb+srv://<username>:<password>@cluster.mongodb.net/agflix?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/agflix

# JWT Secrets (Minimum 32 characters)
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_secret_key_32_chars_min
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_secret_key_32_chars_min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cookies
COOKIE_SECRET=your_super_secret_cookie_parser_signed_secret_key_32_chars_min

# Client Routing
FRONTEND_URL=http://localhost:5173

# Nodemailer / Gmail SMTP Config
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=AgFlix Support <noreply@agflix.com>

# Payments (Leave empty if testing locally without transactions)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
